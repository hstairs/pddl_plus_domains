(define
    (problem zermelo_random_${index})

    (:domain zermelo_navigation_problem)
    (:objects
        r0 r1 r2 r3 - region
        the_boat - ship
    )

    (:init
        ;; extent of the "map"
        (= (min_x_global) 0.0)
        (= (max_x_global) 10000.0)
        (= (min_y_global) 0.0)
        (= (max_y_global) 10000.0)

        ;; Initial boat location, heading and velocity
        (= (x the_boat) ${x0_boat})
        (= (y the_boat) ${y0_boat})
        (= (velocity the_boat) 5.144) ;; speed is 10 knots or 5.144 m/s
        (= (theta the_boat) ${theta0_boat}) ;; initial heading is ${theta0_boat_degrees} deg, measured wrt to the boat's prow
        (= (turn_rate the_boat) 0.0174533) ;; turn rate is 1 degree / second
        (ahead the_boat) ;; boat starts going steady

        ;; Region properties
        ;; Region 0, wind velocity is (${r0_u_wind},${r0_v_wind}) about ${r0_wind_speed_knots} knots, direction ${r0_wind_direction} degrees
        (= (wind_x r0) ${r0_u_wind})
        (= (wind_y r0) ${r0_v_wind})
        (= (min_x r0) 0.0)
        (= (min_y r0) 5000.0)
        (= (max_x r0) 5000.0)
        (= (max_y r0) 10000.0)

        ;; Region 1, wind velocity is (${r1_u_wind},${r1_v_wind}) about ${r1_wind_speed_knots} knots, direction ${r1_wind_direction} degrees
        (= (wind_x r1) ${r1_u_wind})
        (= (wind_y r1) ${r1_v_wind})
        (= (min_x r1) 5000.0)
        (= (min_y r1) 5000.0)
        (= (max_x r1) 10000.0)
        (= (max_y r1) 10000.0)

        ;; Region 2, wind velocity is (${r2_u_wind},${r2_v_wind}) about ${r2_wind_speed_knots} knots, direction ${r2_wind_direction} degrees
        (= (wind_x r2) ${r2_u_wind})
        (= (wind_y r2) ${r2_v_wind})
        (= (min_x r2) 0.0)
        (= (min_y r2) 0.0)
        (= (max_x r2) 5000.0)
        (= (max_y r2) 5000.0)

        ;; Region 3, wind velocity is (${r3_u_wind},${r3_v_wind}) about ${r3_wind_speed_knots} knots, direction ${r3_wind_direction} degrees
        (= (wind_x r3) ${r3_u_wind})
        (= (wind_y r3) ${r3_v_wind})
        (= (min_x r3) 5000.0)
        (= (min_y r3) 0.0)
        (= (max_x r3) 10000.0)
        (= (max_y r3) 5000.0)


    )

    (:goal
        (and
            (>= (x the_boat) 8000.0)
            (>= (y the_boat) 8000.0)
            (<= (x the_boat) 9000.0)
            (<= (y the_boat) 9000.0)
        )

    )

)
